{
  "name": "drift-testing",
  "version": "0.1.0",
  "description": "Testing utilities for Drift Framework",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "drift": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "vitest": "^1.4.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "drift": ">=0.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
