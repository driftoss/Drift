{
  "name": "drift",
  "version": "0.1.0",
  "description": "High-Performance Microservices Framework for Node.js",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs",
      "types": "./dist/server/index.d.ts"
    },
    "./router": {
      "import": "./dist/router/index.js",
      "require": "./dist/router/index.cjs",
      "types": "./dist/router/index.d.ts"
    },
    "./decorators": {
      "import": "./dist/decorators/index.js",
      "require": "./dist/decorators/index.cjs",
      "types": "./dist/decorators/index.d.ts"
    },
    "./container": {
      "import": "./dist/container/index.js",
      "require": "./dist/container/index.cjs",
      "types": "./dist/container/index.d.ts"
    },
    "./middleware": {
      "import": "./dist/middleware/index.js",
      "require": "./dist/middleware/index.cjs",
      "types": "./dist/middleware/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup && tsc --declaration --declarationMap --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2",
    "zod": "^3.22.4",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "vitest": "^1.4.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npmjs.com/"
  }
}
