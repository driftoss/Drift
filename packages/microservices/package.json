{
  "name": "drift-microservices",
  "version": "0.1.0",
  "description": "Microservices module for Drift Framework",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup && tsc --declaration --declarationMap --outDir dist",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "drift": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "redis": "^4.6.12"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "vitest": "^1.4.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "drift": ">=0.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
